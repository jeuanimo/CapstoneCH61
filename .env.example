# ========================================
# Django Core Settings
# ========================================
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,ngs1914.org,www.ngs1914.org

# ========================================
# Database Configuration
# ========================================
# Development: Leave commented to use SQLite
# Production: Set DATABASE_URL for PostgreSQL
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE_NAME

# Local PostgreSQL example:
# DATABASE_URL=postgres://chapter_user:password@localhost:5432/chapter_database

# Render.com PostgreSQL (auto-set by Render):
# DATABASE_URL=postgres://user:password@hostname.render.com:5432/dbname

# ========================================
# Production Security (Render.com)
# ========================================
# Set this to your domain (required for CSRF protection)
CSRF_TRUSTED_ORIGINS=https://ngs1914.org,https://www.ngs1914.org

# ========================================
# Email Configuration (Namecheap Private Email)
# ========================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mail.privateemail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=contact@ngs1914.org
EMAIL_HOST_PASSWORD=your-email-password-here
DEFAULT_FROM_EMAIL=contact@ngs1914.org
CONTACT_EMAIL=contact@ngs1914.org

# ========================================
# Zoom Meeting SDK Configuration
# ========================================
# Option 1: Use environment variables (recommended for production)
# These override database configuration if set

# Meeting SDK Credentials (Required for embedded meetings)
# Get from: Zoom Marketplace > Build App > Meeting SDK
ZOOM_MEETING_SDK_KEY=your-zoom-sdk-key
ZOOM_MEETING_SDK_SECRET=your-zoom-sdk-secret

# Server-to-Server OAuth Credentials (Required for Host Mode)
# Get from: Zoom Marketplace > Build App > Server-to-Server OAuth
# Host mode requires ZAK token which is fetched via OAuth API
ZOOM_OAUTH_ACCOUNT_ID=your-zoom-account-id
ZOOM_OAUTH_CLIENT_ID=your-oauth-client-id
ZOOM_OAUTH_CLIENT_SECRET=your-oauth-client-secret

# Option 2: Use database configuration
# Configure Zoom credentials in Django Admin > Pages > Zoom Configuration
# Database config is used if environment variables are not set

# ========================================
# Stripe Payment Configuration
# ========================================
# Get keys from: https://dashboard.stripe.com/apikeys
# Test mode: Use keys starting with pk_test_ and sk_test_
# Live mode: Use keys starting with pk_live_ and sk_live_

# Required for payments
STRIPE_PUBLIC_KEY=pk_test_your-publishable-key
STRIPE_SECRET_KEY=sk_test_your-secret-key

# Required for webhook verification (from Stripe Dashboard > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# NOTE: Your bank account info is configured in Stripe Dashboard, NOT here.
# Stripe handles all sensitive banking/card data - your server never sees it.

# ========================================
# Cloudinary Media Storage (Production)
# ========================================
# Required for persistent media files on Render.com (user uploads)
# Without this, uploaded files are lost on each deploy!
#
# Sign up (free): https://cloudinary.com/
# Find your URL: Dashboard > Account Details > Environment Variable
#
# Format: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Example: cloudinary://123456789012345:abcDEF123xyz@my-cloud-name
CLOUDINARY_URL=cloudinary://your-api-key:your-api-secret@your-cloud-name